# suppress

# ─── Allocation capacity overflow (never triggers in practice) ──
# capacity_overflow only fires when usize arithmetic overflows during
# Vec/String resizing — effectively impossible on 64-bit systems.
alloc::raw_vec::capacity_overflow=

# ─── char/unicode methods: S from reading immutable static tables ──
# These functions read `static` arrays of Unicode property data (e.g.
# SHORT_OFFSET_RUNS). The arrays are pure compile-time constant data
# with no interior mutability — reading them is semantically pure.
# The linter marks them S because it cannot distinguish immutable
# data tables from mutable global state.

# char methods that delegate to unicode lookup tables
core::char::methods::char::is_alphabetic=
